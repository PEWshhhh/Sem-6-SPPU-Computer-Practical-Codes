# A* Algorithm for Wumpus World (Dynamic Grid)

# Function for safe input

def get_position(message, size):

    while True:

        value = int(input(message))

        # Negative check
        if value < 0:

            print("Negative values not allowed")

        # Range check
        elif value >= size:

            print("Value out of range")

        else:
            return value


# Heuristic Function
# Manhattan Distance

def heuristic(current, goal):

    x1 = current[0]
    y1 = current[1]

    x2 = goal[0]
    y2 = goal[1]

    return abs(x1 - x2) + abs(y1 - y2)


# Grid Size

size = int(input("Enter Grid Size : "))

# Create Empty Grid

grid = []

for i in range(size):

    row = []

    for j in range(size):

        row.append(' ')

    grid.append(row)


# Start and Goal

start = (0, 0)
goal = (size - 1, size - 1)

grid[0][0] = 'S'
grid[size - 1][size - 1] = 'G'


# Pit Position

while True:

    pit_row = get_position("Enter Pit Row : ", size)
    pit_col = get_position("Enter Pit Col : ", size)

    # Prevent overlap with Start and Goal

    if (pit_row, pit_col) == start:

        print("Pit cannot be placed at Start")

    elif (pit_row, pit_col) == goal:

        print("Pit cannot be placed at Goal")

    else:

        grid[pit_row][pit_col] = 'P'
        break


# Wumpus Position

while True:

    w_row = get_position("Enter Wumpus Row : ", size)
    w_col = get_position("Enter Wumpus Col : ", size)

    # Prevent overlap

    if (w_row, w_col) == start:

        print("Wumpus cannot be placed at Start")

    elif (w_row, w_col) == goal:

        print("Wumpus cannot be placed at Goal")

    elif grid[w_row][w_col] == 'P':

        print("Wumpus cannot be placed on Pit")

    else:

        grid[w_row][w_col] = 'W'
        break


# Display Grid

print("\nGrid :")

for row in grid:
    print(row)


# A* Algorithm

open_list = []
visited = []

# (f value, current position, path)

open_list.append((0, start, [start]))


while len(open_list) > 0:

    # Sort according to minimum f(n)

    open_list.sort()

    current_node = open_list.pop(0)

    f = current_node[0]
    current_position = current_node[1]
    path = current_node[2]

    # Goal Check

    if current_position == goal:

        print("\nGold Found")
        print("Safe Path : ")

        for p in path:
            print(p)

        break


    # Visit once

    if current_position not in visited:

        visited.append(current_position)

        row = current_position[0]
        col = current_position[1]

        # Possible Movements

        neighbours = [

            (row - 1, col),   # Up
            (row + 1, col),   # Down
            (row, col - 1),   # Left
            (row, col + 1)    # Right
        ]


        for next_position in neighbours:

            r = next_position[0]
            c = next_position[1]

            # Boundary Check

            if r >= 0 and r < size and c >= 0 and c < size:

                # Avoid Pit and Wumpus

                if grid[r][c] != 'P' and grid[r][c] != 'W':

                    # g(n) = path cost
                    g = len(path)

                    # h(n) = heuristic value
                    h = heuristic(next_position, goal)

                    # f(n) = g(n) + h(n)

                    f = g + h

                    new_path = path + [next_position]

                    open_list.append((f, next_position, new_path))


else:

    print("\nNo Safe Path Found")












# ---------------- THEORY ----------------

# Artificial Intelligence uses search algorithms
# to solve path finding and decision making problems.

# A* (A-Star) Algorithm is one of the most popular
# informed search algorithms.

# It is used to find the shortest and safest path
# from start node to goal node.

# A* combines:
# 1) Actual path cost
# 2) Estimated future cost

# Formula used in A*:

# f(n) = g(n) + h(n)

# Where:
# g(n) = Actual distance travelled from start node
# h(n) = Estimated distance from current node to goal
# f(n) = Total estimated cost

# The node having smallest f(n) value
# is selected first.

# In this program:
# S = Start Position
# G = Gold / Goal
# P = Pit
# W = Wumpus
# B = Breeze

# Pit and Wumpus are dangerous cells.
# The agent should avoid these cells.

# Breeze is an indicator that Pit is nearby.

# This program uses Manhattan Distance
# as heuristic function.

# Manhattan Distance Formula:

# h(n) = |x1 - x2| + |y1 - y2|

# This heuristic is suitable because
# movement is allowed only in:
# Up, Down, Left and Right directions.

# Diagonal movement is not allowed.

# The objective of this program is:
# To safely reach Gold while avoiding
# Pit and Wumpus.



