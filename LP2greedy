    min_distance = INF
    min_index = -1

    for j in range(vertices):

        if visited[j] == 0 and distance[j] < min_distance:

            min_distance = distance[j]
            min_index = j

    visited[min_index] = 1

    for k in range(vertices):

        if graph[min_index][k] != 0 and visited[k] == 0:

            new_distance = distance[min_index] + graph[min_index][k]

            if new_distance < distance[k]:

                distance[k] = new_distance

print("\nShortest Distances:")

