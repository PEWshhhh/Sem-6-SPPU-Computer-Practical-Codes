# Minimum Spanning Tree

vertices = int(input("Enter number of vertices: "))
edges_count = int(input("Enter number of edges: "))

edges = []

print("Enter edges in format: source destination weight")

for i in range(edges_count):

    u = int(input("Enter source vertex: "))
    v = int(input("Enter destination vertex: "))
    w = int(input("Enter weight: "))

    edges.append((w, u, v))

edges.sort()

parent = []

for i in range(vertices):
    parent.append(i)


def find(i):

    while parent[i] != i:
        i = parent[i]

    return i


def union(a, b):

    parent_a = find(a)
    parent_b = find(b)

    parent[parent_a] = parent_b


print("\nEdges in Minimum Spanning Tree:")

count = 0
index = 0
total_cost = 0

while count < vertices - 1:

    weight, u, v = edges[index]
    index = index + 1

    parent_u = find(u)
    parent_v = find(v)

    if parent_u != parent_v:

        print(u, "--", v, "=", weight)

        total_cost = total_cost + weight

        union(parent_u, parent_v)

        count = count + 1

print("\nTotal Cost of MST:", total_cost)


