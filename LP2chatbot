# Function for taking only yes/no input
def get_answer(question):

    while True:

        answer = input(question).strip().lower()

        if answer == "yes" or answer == "no":
            return answer == "yes"

        else:
            print("Invalid input!")
            print("Please type only 'yes' or 'no'\n")


# Main Chatbot Function
def medical_expert_system():

    print("==== Medical Diagnosis Chatbot ====")
    print("Please answer with only 'yes' or 'no'\n")

    # Gather symptoms
    symptoms = {

        'fever': get_answer("Do you have a fever? "),

        'cough': get_answer("Do you have a cough? "),

        'headache': get_answer("Do you have a severe headache? "),

        'sore_throat': get_answer("Do you have a sore throat? ")
    }

    print("\n==== Diagnosis Result ====")

    # Rule Engine
    if symptoms['fever'] and symptoms['cough'] and symptoms['sore_throat']:

        print("Diagnosis: You might have Flu or Viral Infection.")
        print("Advice: Please consult a doctor and take proper rest.")

    elif symptoms['fever'] and symptoms['headache']:

        print("Diagnosis: You might have Viral Fever or Dengue.")
        print("Advice: Drink plenty of water and monitor temperature.")

    elif symptoms['cough'] and symptoms['sore_throat']:

        print("Diagnosis: You may have Common Cold.")
        print("Advice: Drink warm fluids and take rest.")

    elif symptoms['headache']:

        print("Diagnosis: You may be experiencing Stress or Migraine.")
        print("Advice: Relax and get enough sleep.")

    else:

        print("Diagnosis: Symptoms are unclear or mild.")
        print("Advice: Visit a general physician if needed.")


# Function Call
medical_expert_system()








