def printBoard(board, n):

    print("\nSolution:\n")

    for i in range(n):

        for j in range(n):

            if board[i][j] == 1:
                print("Q", end=" ")

            else:
                print(".", end=" ")

        print()


# Function to check safe position
def isSafe(row, col, leftRow, upperDiagonal, lowerDiagonal, n):

    if leftRow[col] == 1:
        return False

    if lowerDiagonal[row + col] == 1:
        return False

    if upperDiagonal[n - 1 + col - row] == 1:
        return False

    return True


# Backtracking function
def solve(board, row, n, leftRow, upperDiagonal, lowerDiagonal):

    # All queens placed
    if row == n:
        printBoard(board, n)
        return True

    # Try all columns
    for col in range(n):

        # Check safe position
        if isSafe(row, col, leftRow, upperDiagonal, lowerDiagonal, n):

            # Place queen
            board[row][col] = 1

            # Mark column and diagonals
            leftRow[col] = 1
            lowerDiagonal[row + col] = 1
            upperDiagonal[n - 1 + col - row] = 1

            # Move to next row
            if solve(board, row + 1, n, leftRow, upperDiagonal, lowerDiagonal):
                return True

            # Backtracking
            board[row][col] = 0

            leftRow[col] = 0
            lowerDiagonal[row + col] = 0
            upperDiagonal[n - 1 + col - row] = 0

    return False


# ---------------- MAIN PROGRAM ----------------

# Dynamic input
n = int(input("Enter number of queens: "))

# Create board dynamically
board = []

for i in range(n):

    row = []

    for j in range(n):
        row.append(0)

    board.append(row)

# Arrays for Branch and Bound
leftRow = [0] * n
upperDiagonal = [0] * (2 * n - 1)
lowerDiagonal = [0] * (2 * n - 1)

# Solve problem
result = solve(board, 0, n, leftRow, upperDiagonal, lowerDiagonal)

if result == False:
    print("No solution exists")





